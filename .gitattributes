# ============================================================
# YAPCRPlayer .gitattributes
# 既定はテキスト自動判定＋チェックアウト時 LF 正規化。
# Windows 専用のスクリプト/プロジェクトファイルのみ CRLF を強制。
# ============================================================

# 既定: テキストは自動判定し、リポジトリ内は LF に正規化
* text=auto eol=lf

# ---- LF を強制するテキスト ----
*.cpp   text eol=lf
*.h     text eol=lf
*.hpp   text eol=lf
*.c     text eol=lf
*.cc    text eol=lf
*.cmake text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.def   text eol=lf

# ---- CRLF を強制する Windows 専用ファイル ----
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.sln   text eol=crlf
*.vcxproj      text eol=crlf
*.vcxproj.filters text eol=crlf

# ---- バイナリ（差分・正規化を無効化） ----
# BBS テストフィクスチャ: Shift_JIS / EUC-JP バイナリは text=auto で破損するため除外
tests/fixtures/bbs/**/*.dat  binary
*.dll   binary
*.lib   binary
*.exe   binary
*.pdb   binary
*.exp   binary
*.7z    binary
*.zip   binary
*.png   binary
*.jpg   binary
*.ico   binary
*.qm    binary

# 言語統計から外部/参照ツリーを除外（GitHub Linguist）
PCRPlayer/**       linguist-vendored
mpv/**             linguist-vendored
peercaststation/** linguist-vendored
